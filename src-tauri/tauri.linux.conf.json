{
	"$schema": "https://schema.tauri.app/config/2",
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Helmor",
				"titleBarStyle": "Visible",
				"decorations": true,
				"transparent": false
			}
		]
	},
	"bundle": {
		"linux": {
			"deb": {
				"depends": [
					"libwebkit2gtk-4.1-0",
					"libsoup-3.0-0",
					"libgtk-3-0t64",
					"librsvg2-2",
					"libayatana-appindicator3-1"
				]
			},
			"appimage": {
				"bundleMediaFramework": true
			}
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.png"
		]
	}
}
